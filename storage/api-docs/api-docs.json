{
    "openapi": "3.0.0",
    "info": {
        "title": "Brigade API",
        "description": "API documentation for Brigade restaurant management system",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "Local server"
        }
