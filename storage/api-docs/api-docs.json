                "summary": "Create new plat",
                "operationId": "createPlat",
                "requestBody": {
                    "required": true,
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "required": [
                                    "name",
                                    "price",
                                    "category_id"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Pizza Margherita"
                                    },
                                    "description": {
                                        "type": "string",
                                        "example": "Italian pizza"
                                    },
                                    "price": {
                                        "type": "number",
                                        "example": 12.5
                                    },
                                    "category_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "image": {
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Plat created successfully"
